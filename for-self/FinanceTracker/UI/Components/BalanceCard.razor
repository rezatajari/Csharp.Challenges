<div class="card shadow-sm border-0 mt-3" style="border-radius: 15px; background: linear-gradient(45deg, #1e3c72, #2a5298); color: white;">
    <div class="card-body p-4">
        <h6 class="text-uppercase mb-2" style="opacity: 0.8; font-size: 0.75rem; letter-spacing: 1px;">Total Balance</h6>
        <h2 class="display-5 fw-bold mb-0">@Amount.ToString("C")</h2>
        <div class="mt-3">
            <span class="badge bg-success">
                <i class="bi bi-arrow-up-short"></i> +2.5% this month
            </span>
        </div>
    </div>
</div>

@code {
    // This allows the Home page to "pass" a number into this card
    [Parameter]
    public decimal Amount { get; set; } = 0;
}