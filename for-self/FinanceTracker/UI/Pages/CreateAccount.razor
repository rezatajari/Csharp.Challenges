@page "/create-account"
@using Application.Dtos
@using Domain.Entities
@using Domain.ValueObjects
@inject NavigationManager Navigation
@using UI.Services
@inject AccountService accService

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0" style="border-radius: 15px;">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-3">Open New Account</h3>

                    <EditForm Model="@formModel" OnValidSubmit="HandleSubmit">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger d-flex align-items-center" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <div>@errorMessage</div>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Account Type</label>
                            <InputSelect class="form-select form-control-lg" @bind-Value="formModel.Type">
                                <option value="@AccountType.Savings">Savings Account</option>
                                <option value="@AccountType.CreditCard">Credit Card Account</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Account Name</label>
                            <InputText class="form-control form-control-lg" @bind-Value="formModel.Name" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Initial Balance</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber class="form-control form-control-lg" @bind-Value="formModel.Amount" />
                            </div>
                        </div>

                        @if (formModel.Type == AccountType.CreditCard)
                        {
                            <div class="mb-4 p-3 bg-light rounded-3 border">
                                <label class="form-label fw-bold text-primary">Credit Limit</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-primary text-white">$</span>
                                    <InputNumber class="form-control form-control-lg" @bind-Value="formModel.CreditLimitAmount" />
                                </div>
                                <small class="text-muted">Define the maximum credit for this card.</small>
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span> Processing...</span>
                            }
                            else
                            {
                                <span>Confirm & Create</span>
                            }
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private FormModel formModel = new();
    private string? errorMessage; 
    private bool isSubmitting;    

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null; 

        var dto = new CreateAccountDto(
            formModel.Name,
            Money.Create(formModel.Amount, Currency.USD),
            formModel.Type,
            formModel.Type == AccountType.CreditCard
                ? Money.Create(formModel.CreditLimitAmount, Currency.USD)
                : Money.Default()
        );

        var result = await accService.CreateAccount(dto);

        if (result.IsSuccess)
        {
            Navigation.NavigateTo("/accounts");
        }
        else
        {
            errorMessage = result.ErrorMessage;
        }

        isSubmitting = false;
    }

    private class FormModel
    {
        public string Name { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public AccountType Type { get; set; } = AccountType.Savings;

        public decimal CreditLimitAmount { get; set; }
    }
}