@page "/create-account"
@using Application.Dtos
@using Domain.ValueObjects

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0" style="border-radius: 15px;">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-3">Open New Account</h3>
                    <p class="text-muted mb-4">Fill in the details to start your new financial journey.</p>

                    <EditForm Model="@formModel" OnValidSubmit="HandleSubmit">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Account Name</label>
                            <InputText class="form-control form-control-lg"
                                       @bind-Value="formModel.Name"
                                       placeholder="e.g. Daily Expenses" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Initial Balance</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber class="form-control form-control-lg"
                                             @bind-Value="formModel.Amount" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100" style="border-radius: 10px;">
                            Confirm & Create
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private FormModel formModel = new();

    private void HandleSubmit()
    {
        var accountModel = new CreateAccountDto(
            formModel.Name,
            Money.Create(formModel.Amount, Currency.USD)
    );

        Console.WriteLine($"Ready to send to Server: {accountModel.Name} with {accountModel.Balance.Amount}");

    }

    public class FormModel
    {
        public string Name { get; set; } = string.Empty;
        public decimal Amount { get; set; }
    }
}