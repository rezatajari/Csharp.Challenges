@page "/accounts"
@using Application.Dtos
@using UI.Services
@inject AccountService AccountService

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">My Accounts</h2>
        <a href="/create-account" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New Account
        </a>
    </div>


    @if (message == "created")
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> Your new account has been created successfully.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (accounts == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading your accounts...</p>
        </div>
    }
    else if (!accounts.Any())
    {
        <div class="alert alert-info">
            You haven't opened any accounts yet. Click "New Account" to start!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var acc in accounts)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="border-radius: 15px;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="card-title fw-bold mb-1">@acc.Name</h5>
                                    <span class="badge @(acc.Type == AccountType.CreditCard ? "bg-info" : "bg-success") mb-3">
                                        @acc.Type
                                    </span>
                                </div>
                                <i class="bi @(acc.Type == AccountType.CreditCard ? "bi-credit-card" : "bi-piggy-bank") fs-3 text-muted"></i>
                            </div>

                            <h3 class="fw-bold text-dark">@acc.Balance.Amount.ToString("C")</h3>

                            @if (acc.Type == AccountType.CreditCard)
                            {
                                <div class="mt-2 small text-muted">
                                    Limit: @acc.CreditLimit.Amount.ToString("C")
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3">
                            <button class="btn btn-outline-primary btn-sm w-100">View Details</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<AccountDto>? accounts;
    [SupplyParameterFromQuery]
    public string? message { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var result = await AccountService.GetAllAccounts();
        if (result.IsSuccess)
        {
            accounts = result.Value;
        }
    }


}
