@page "/account-details/{Id:int}"
@using Application.Dtos
@using Domain.Entities
@using Domain.ValueObjects
@using UI.Components
@using UI.Services
@inject FinanceService _accService

<h3>Account Details</h3>

@if (isLoading)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>@ErrorMessage</div>
    </div>
}
else
{
    <div class="card shadow-sm p-4">
        <h4>@account.Name</h4>
        <p>Type: @account.Type</p>
        <p>Balance: @account.Balance.Amount.ToString("C")</p>
    </div>
}



<h4 calss="fw-bold mt-4 mb-3">Transaction History</h4>
@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @statusClass alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
    </div>
}
<button class="btn btn-primary mb-3" @onclick="()=>transactionModal.Show()">Add Transaction</button>
<TransactionTable Transaction="transactions"></TransactionTable>



@code {
    [Parameter]
    public int Id { get; set; }
    private AccountDto? account;
    private List<TransactionDto> transactions = new();
    private TransactionFormModal transactionModal;
    private TransactionFrom formModel = new();
    private List<AccountDto> otherAccounts = new();
    private string? ErrorMessage;
    private bool isLoading = true;
    private string? statusMessage;
    private string statusClass = "";

    protected override async Task OnInitializedAsync()
    {
        formModel.AccountId = Id;
        var accountResult = await _accService.GetAccount(Id);
        if (accountResult.IsSuccess)
        {
            account = accountResult.Value;
            var txResult = await _accService.GetTransactionsByAccountId(Id);

            if (txResult.IsSuccess)
                transactions = txResult.Value;
        }
        else
        {
            ErrorMessage = accountResult.ErrorMessage;
        }

        isLoading = false;
    }

    private async Task LoadOtherAccounts()
    {
        var result = await _accService.GetAllAccounts();
        if (result.IsSuccess)
        {
            otherAccounts = result.Value.Where(a => a.Id != Id).ToList();

            StateHasChanged();
        }

    }


    private async Task SaveTransaction()
    {
        var result = await _accService.AddTransaction(formModel);

        if (result.IsSuccess)
        {
            statusMessage = "Transaction added successfully!";
            statusClass = "alert-success";

            transactionModal.Hide();

            var txResult = await _accService.GetTransactionsByAccountId(Id);
            if (txResult.IsSuccess)
            {
                transactions = txResult.Value;
            }
        }
        else
        {
            statusMessage = $"Error: {result.ErrorMessage}";
            statusClass = "alert-danger";
            transactionModal.Hide();
        }
    }

    public class TransactionFrom
    {
        public int AccountId { get; set; } 
        public int TargetAccountId { get; set; }
        public decimal Amount { get; set; }
        public Currency Currency { get; set; } = Currency.USD;
        public string CategoryName { get; set; } 
        public string? CategoryDescription { get; set; } 
        public TransactionType Type { get; set; }
        public string? TransactionDescription { get; set; }
    }
}