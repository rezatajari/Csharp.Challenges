@using Application.Dtos.Requests
@using Application.Shared.Validators
@using Domain.Entities
@using Domain.ValueObjects
@using UI.Models
@using FluentValidation

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">

                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold text-dark">
                        <i class="bi bi-plus-circle text-emerald me-2"></i>Create New Account
                    </h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>

                <EditForm Model="@_vm" OnValidSubmit="HandleValidSubmit">
                    <div class="modal-body px-4">
                        @if (!string.IsNullOrEmpty(_customError))
                        {
                            <div class="alert alert-danger border-0 small shadow-sm d-flex align-items-center mb-4">
                                <i class="bi bi-exclamation-circle-fill me-2"></i> @_customError
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Account Name</label>
                            <InputText @bind-Value="_vm.Name" class="form-control form-control-lg rounded-3 fs-6" placeholder="e.g., Daily Expenses" />
                            <ValidationMessage For="@(() => _vm.Name)" class="text-danger small" />
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-7">
                                <label class="form-label small fw-bold text-muted text-uppercase">Initial Balance</label>
                                <InputNumber @bind-Value="_vm.Amount" class="form-control form-control-lg rounded-3 fs-6" />
                                <ValidationMessage For="@(() => _vm.Amount)" class="text-danger small" />
                            </div>
                            <div class="col-5">
                                <label class="form-label small fw-bold text-muted text-uppercase">Currency</label>
                                <InputSelect @bind-Value="_vm.Currency" class="form-select form-control-lg rounded-3 fs-6">
                                    @foreach (var curr in Enum.GetValues<Currency>())
                                    {
                                        <option value="@curr">@curr</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Account Type</label>
                            <InputSelect @bind-Value="_vm.Type" class="form-select form-control-lg rounded-3 fs-6">
                                @foreach (var type in Enum.GetValues<AccountType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </InputSelect>
                        </div>

                        @if (_vm.Type == AccountType.CreditCard)
                        {
                            <div class="p-3 mb-3 bg-light rounded-3 border-start border-emerald border-4">
                                <label class="form-label small fw-bold text-emerald text-uppercase">Credit Limit</label>
                                <InputNumber @bind-Value="_vm.CreditLimitAmount" class="form-control rounded-3" />
                                <ValidationMessage For="@(() => _vm.CreditLimitAmount)" class="text-danger small" />
                                <div class="form-text mt-2" style="font-size: 0.75rem;">This defines the spending ceiling for this card.</div>
                            </div>
                        }
                    </div>

                    <div class="modal-footer border-top-0 pb-4 px-4">
                        <button type="button" class="btn btn-light px-4 fw-semibold text-muted" @onclick="Close">Cancel</button>
                        <button type="submit" class="btn btn-emerald px-4 fw-bold shadow-sm">Save Account</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .text-emerald {
        color: #157347 !important;
    }

    .border-emerald {
        border-color: #157347 !important;
    }

    .btn-emerald {
        background-color: #157347;
        border-color: #157347;
        color: white;
        transition: all 0.2s;
    }

        .btn-emerald:hover {
            background-color: #0e5a36;
            color: white;
            transform: translateY(-1px);
        }

    .form-control:focus, .form-select:focus {
        border-color: #157347;
        box-shadow: 0 0 0 0.25rem rgba(21, 115, 71, 0.15);
    }

    /* Modernizing the Inputs */
    .form-control-lg, .form-select-lg {
        border: 1.5px solid #dee2e6;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<CreateAccountRequest> OnSave { get; set; }
    private CreateAccountModalForm _vm = new();
    private string? _customError;

    private Task Close() => OnClose.InvokeAsync();

    private async Task HandleValidSubmit()
    {
        _customError = null;

        var request = new CreateAccountRequest
        {
            Name = _vm.Name,
            Type = _vm.Type,
            Balance = Money.Create(_vm.Amount, _vm.Currency),
            CreditLimit = _vm.Type == AccountType.CreditCard
                ? Money.Create(_vm.CreditLimitAmount, _vm.Currency)
                : Money.Default()
        };

        var validator = new CreateAccountRequestValidator();
        var result = await validator.ValidateAsync(request);

        if (result.IsValid)
        {
            await OnSave.InvokeAsync(request);
            _vm = new();
        }
        else
        {
            _customError = result.Errors.FirstOrDefault()?.ErrorMessage;
        }
    }
}