@using Application.Dtos.Requests
@using UI.Services.Interfaces
@inject IFinanceService FinanceService

<div class="d-inline-block">
    <button class="btn btn-emerald px-4 py-2 fw-bold shadow-sm rounded-3 d-flex align-items-center" @onclick="ShowModal">
        <i class="bi bi-plus-circle-fill me-2 fs-5"></i>
        <span>Add Account</span>
    </button>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3 border-0 shadow-sm d-flex align-items-center animate-fade-in" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@_errorMessage</div>
        </div>
    }
</div>

<CreateAccountModal IsVisible="_showModal"
                    OnClose="CloseModal"
                    OnSave="HandleCreateAccount" />

<style>
    .btn-emerald {
        background-color: #157347;
        border-color: #157347;
        color: white;
        transition: all 0.3s ease;
    }

        .btn-emerald:hover {
            background-color: #0e5a36;
            border-color: #0e5a36;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(21, 115, 71, 0.3);
        }

        .btn-emerald:active {
            transform: translateY(0);
        }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@code {
    [Parameter] public EventCallback OnAccountCreated { get; set; }

    private bool _showModal;
    private string? _errorMessage;

    private void ShowModal()
    {
        _errorMessage = null; // Clear previous errors when reopening
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task HandleCreateAccount(CreateAccountRequest request)
    {
        _errorMessage = null;
        var result = await FinanceService.CreateAccountAsync(request);

        if (result.IsSuccess)
        {
            _showModal = false;
            await OnAccountCreated.InvokeAsync();
        }
        else
        {
            _errorMessage = result.ErrorMessage;
        }
    }
}