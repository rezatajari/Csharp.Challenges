@using Application.Dtos
@using Application.Dtos.Reponses
@using Application.Dtos.Requests
@using Domain.Entities
@using Domain.ValueObjects
@using UI.Models
@using UI.Services
@using UI.Services.Interfaces
@inject IFinanceService FinanceService

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(5px);" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

                @* Dark Header to contrast with the light form *@
                <div class="modal-header bg-dark text-white border-0 py-4 px-4">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-plus-circle text-emerald me-2"></i> New Transaction
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="Hide"></button>
                </div>

                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert @statusClass border-0 shadow-sm rounded-3 d-flex align-items-center animate-fade-in" role="alert">
                            <i class="bi @(statusClass.Contains("success") ? "bi-check-circle-fill" : "bi-exclamation-octagon-fill") me-2"></i>
                            <div>@statusMessage</div>
                        </div>
                    }

                    @* Transaction Type Toggle - Emerald themed *@
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2">Transaction Type</label>
                        <select class="form-select form-select-lg rounded-3 fs-6 border-2" @onchange="OnTransactionTypeChanged">
                            <option value="@TransactionType.Expense">Expense</option>
                            <option value="@TransactionType.Income">Income</option>
                            <option value="@TransactionType.Transfer">Transfer</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2">Amount & Currency</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-end-0 text-emerald fw-bold">
                                <i class="bi bi-cash-stack"></i>
                            </span>
                            <input type="number" class="form-control border-start-0 ps-0 fw-bold text-dark" @bind="addTxModel.Amount" step="0.01" placeholder="0.00" />
                            <select class="form-select border-emerald fw-bold" style="max-width:100px;" @bind="addTxModel.Currency">
                                @foreach (var curr in Enum.GetValues<Currency>())
                                {
                                    <option value="@curr">@curr</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Category</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted">
                                    <i class="bi bi-tag"></i>
                                </span>
                                <input type="text" class="form-control rounded-end-3" @bind="addTxModel.CategoryName" placeholder="e.g. Shopping, Rent, Salary" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2">Description (Optional)</label>
                        <textarea class="form-control rounded-3" @bind="addTxModel.TransactionDescription" rows="2" placeholder="What was this for?"></textarea>
                    </div>

                    @if (addTxModel.Type == TransactionType.Transfer)
                    {
                        <div class="p-3 mb-3 bg-light rounded-3 border-start border-emerald border-4 animate-slide-down">
                            <label class="form-label small fw-bold text-emerald text-uppercase d-block mb-2">Destination Account</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white text-emerald">
                                    <i class="bi bi-arrow-right-circle"></i>
                                </span>
                                <select class="form-select" @bind="addTxModel.TargetAccountId">
                                    <option value="0">-- Select Account --</option>
                                    @foreach (var acc in otherAccounts)
                                    {
                                        <option value="@acc.Id">@acc.Name</option>
                                    }
                                </select>
                            </div>
                            <small class="text-muted mt-2 d-block">Money will be moved from this account to the selected one.</small>
                        </div>
                    }
                </div>

                <div class="modal-footer bg-light border-top-0 py-3 px-4">
                    <button class="btn btn-link text-muted text-decoration-none fw-semibold" @onclick="Hide">Cancel</button>
                    <button class="btn btn-emerald px-5 fw-bold shadow-sm" @onclick="SaveTransaction">
                        <i class="bi bi-check-lg me-2"></i> Save Transaction
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .text-emerald {
        color: #157347 !important;
    }

    .border-emerald {
        border-color: #157347 !important;
    }

    .btn-emerald {
        background-color: #157347;
        border-color: #157347;
        color: white;
        transition: all 0.3s;
    }

        .btn-emerald:hover {
            background-color: #0e5a36;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(21, 115, 71, 0.3);
        }

    .form-control:focus, .form-select:focus {
        border-color: #157347;
        box-shadow: 0 0 0 0.25rem rgba(21, 115, 71, 0.1);
    }

    .animate-fade-in {
        animation: fadeIn 0.3s ease-in;
    }

    .animate-slide-down {
        animation: slideDown 0.3s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public EventCallback<string> OnSave { get; set; }
    private bool IsVisible { get; set; }
    private AddTransactionRequest addTxModel = new();
    private List<AccountResponse> otherAccounts = new();
    private string? statusMessage;
    private string statusClass = "";

    public void Show()
    {
        addTxModel = new AddTransactionRequest { Type = TransactionType.Expense }; // Default to Expense
        statusMessage = null;
        IsVisible = true;
        StateHasChanged();
    }

    public void Hide() => IsVisible = false;

    private async Task SaveTransaction()
    {
        addTxModel.AccountId = Id;
        if (string.IsNullOrWhiteSpace(addTxModel.CategoryName))
            addTxModel.CategoryName = "Uncategorized";

        var result = await FinanceService.AddTransactionAsync(addTxModel);
        if (result.IsSuccess)
        {
            await OnSave.InvokeAsync("Success");
            Hide();
        }
        else
        {
            statusMessage = result.ErrorMessage;
            statusClass = "alert-danger";
        }
    }

    private async Task OnTransactionTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<TransactionType>(e.Value?.ToString(), out var type))
        {
            addTxModel.Type = type;
            if (type == TransactionType.Transfer)
            {
                await LoadOtherAccounts();
            }
        }
    }

    private async Task LoadOtherAccounts()
    {
        var result = await FinanceService.GetAllAccouintsAsync();
        if (result.IsSuccess)
        {
            otherAccounts = result.Value.Where(a => a.Id != Id).ToList();
            StateHasChanged();
        }
    }
}