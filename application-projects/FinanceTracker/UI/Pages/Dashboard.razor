@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using UI.Services.Interfacies
@attribute [Authorize] 
@inject IFinanceService FinanceService

<PageTitle>Dashboard</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <h6 class="card-title">Total Balance</h6>
                    <h2 class="display-6">@_totalBalance.ToString("C")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <h4>Your Accounts</h4>
            @if (_accounts == null)
            {
                <div class="spinner-border text-primary" role="status"></div>
            }
            else if (!_accounts.Any())
            {
                <div class="alert alert-info">No accounts found. Start by adding one!</div>
            }
            else
            {
                <div class="list-group shadow-sm">
                    @foreach (var acc in _accounts)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@acc.Name</strong>
                                <div class="text-muted small">@acc.GetType().Name.Replace("Account", "")</div>
                            </div>
                            <span class="badge bg-success rounded-pill">@acc.Balance.ToString("C")</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>