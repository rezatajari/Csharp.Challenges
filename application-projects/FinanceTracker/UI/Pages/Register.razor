@page "/register"
@using Application.Dtos.Requests
@using UI.Services.Interfaces
@inject IAuthService AuthService
@inject NavigationManager NavManager

<PageTitle>Register - Finance Tracker</PageTitle>

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-light py-5">
    <div class="row w-100 justify-content-center">
        <div class="col-11 col-sm-9 col-md-7 col-lg-5 col-xl-4">

            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-dark text-success rounded-circle shadow-sm mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-person-plus-fill fs-2"></i>
                </div>
                <h2 class="fw-bold text-dark">Create Account</h2>
                <p class="text-muted">Start managing your wealth more effectively</p>
            </div>

            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <EditForm Model="@_model" OnValidSubmit="HandleRegister">
                        <FluentValidationValidator />

                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Username</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="bi bi-person"></i>
                                </span>
                                <InputText @bind-Value="_model.Username" class="form-control border-start-0 ps-0" placeholder="johndoe" />
                            </div>
                            <ValidationMessage For="@(() => _model.Username)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <InputText @bind-Value="_model.Email" class="form-control border-start-0 ps-0" placeholder="name@example.com" />
                            </div>
                            <ValidationMessage For="@(() => _model.Email)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="bi bi-shield-lock"></i>
                                </span>
                                <InputText @bind-Value="_model.Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
                            </div>
                            <ValidationMessage For="@(() => _model.Password)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Confirm Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="bi bi-check2-circle"></i>
                                </span>
                                <InputText @bind-Value="_model.ConfirmPassword" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
                            </div>
                            <ValidationMessage For="@(() => _model.ConfirmPassword)" class="text-danger small mt-1" />
                        </div>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger d-flex align-items-center p-2 small mb-4">
                                <i class="bi bi-exclamation-octagon-fill me-2"></i>
                                <div>@_errorMessage</div>
                            </div>
                        }

                        <button type="submit" class="btn btn-emerald w-100 py-3 fw-bold shadow-sm mt-2" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Creating Account...</span>
                            }
                            else
                            {
                                <span>Register Now</span>
                            }
                        </button>
                    </EditForm>
                </div>
            </div>

            <div class="text-center mt-4 pb-4">
                <p class="text-muted">Already have an account? <NavLink href="login" class="text-success fw-bold text-decoration-none">Sign In</NavLink></p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Shared Branding Colors */
    .btn-emerald {
        background-color: #157347; /* Deep Attractive Green */
        border-color: #157347;
        color: white;
        transition: all 0.3s ease;
    }

        .btn-emerald:hover {
            background-color: #0e5a36;
            border-color: #0e5a36;
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(21, 115, 71, 0.2);
        }

    .text-success {
        color: #157347 !important;
    }

    .form-control:focus {
        border-color: #157347;
        box-shadow: 0 0 0 0.25rem rgba(21, 115, 71, 0.1);
    }

    /* Subtle input group focus effect */
    .input-group:focus-within .input-group-text {
        border-color: #157347;
        color: #157347 !important;
    }
</style>

@code {
    private RegisterUserRequest _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;

    private async Task HandleRegister()
    {
        _isSubmitting = true;
        _errorMessage = null;

        var result = await AuthService.Register(_model);
        if (result.IsSuccess)
        {
            NavManager.NavigateTo("/login");
        }
        else
        {
            _errorMessage = result.ErrorMessage;
        }

        _isSubmitting = false;
    }
}