@page "/login"
@using Application.Dtos.Requests
@using UI.Services
@using UI.Services.Interfaces
@inject IAuthService AuthService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Login - Finance Tracker</PageTitle>

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="row w-100 justify-content-center">
        <div class="col-10 col-sm-8 col-md-6 col-lg-4">

            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-dark text-success rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px;">
                    <i class="bi bi-shield-lock-fill fs-1"></i>
                </div>
                <h2 class="fw-bold text-dark">Welcome Back</h2>
                <p class="text-muted">Securely access your financial dashboard</p>
            </div>

            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <EditForm Model="@_model" OnValidSubmit="HandleLogin">
                        <FluentValidationValidator />

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <InputText @bind-Value="_model.Email" class="form-control border-start-0 ps-0" placeholder="name@example.com" />
                            </div>
                            <ValidationMessage For="@(() => _model.Email)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="bi bi-key"></i>
                                </span>
                                <InputText @bind-Value="_model.Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
                            </div>
                            <ValidationMessage For="@(() => _model.Password)" class="text-danger small mt-1" />
                        </div>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger d-flex align-items-center p-2 small mb-4" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <div>@_errorMessage</div>
                            </div>
                        }

                        <button type="submit" class="btn btn-emerald w-100 py-3 fw-bold shadow-sm" disabled="@_isLogin">
                            @if (_isLogin)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Signing in...</span>
                            }
                            else
                            {
                                <span>Log In</span>
                            }
                        </button>
                    </EditForm>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted">Don't have an account? <NavLink href="register" class="text-success fw-bold text-decoration-none">Create one</NavLink></p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom "Attractive Green" - Deep Emerald */
    .btn-emerald {
        background-color: #157347; /* Darker than default success */
        border-color: #157347;
        color: white;
        transition: all 0.3s ease;
    }

        .btn-emerald:hover {
            background-color: #0e5a36;
            border-color: #0e5a36;
            color: white;
            transform: translateY(-1px);
            shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

        .btn-emerald:active {
            transform: translateY(0);
        }

    /* Form focus effects */
    .form-control:focus {
        border-color: #157347;
        box-shadow: 0 0 0 0.25rem rgba(21, 115, 71, 0.15);
    }

    .text-success {
        color: #157347 !important;
    }
</style>

@code {
    private LoginUserRequest _model = new();
    private string? _errorMessage;
    private bool _isLogin;

    private async Task HandleLogin()
    {
        _isLogin = true;
        _errorMessage = null;
        var result = await AuthService.Logn(_model);
        if (result.IsSuccess)
        {
            NavManager.NavigateTo("/dashboard");
        }
        else
        {
            _errorMessage = result.ErrorMessage;
        }

        _isLogin = false;
    }
}