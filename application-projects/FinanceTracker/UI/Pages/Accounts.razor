@page "/accounts"
@using Application.Dtos
@using Application.Dtos.Reponses
@using Application.Dtos.Requests
@using Domain.Entities
@using Domain.ValueObjects
@using Microsoft.AspNetCore.Authorization
@using UI.Components
@using UI.Services.Interfaces
@inject IFinanceService FinanceService
@inject NavigationManager Nav
@attribute [Authorize]

<PageTitle>My Accounts - Finance Tracker</PageTitle>

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-0">Manage Accounts</h2>
            <p class="text-muted small">View, edit, or remove your financial accounts.</p>
        </div>
        <AddAccountAction OnAccountCreated="OnInitializedAsync" />
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@_errorMessage</div>
        </div>
    }

    @if (accountlist == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-emerald" role="status"></div>
            <p class="mt-2 text-muted">Fetching your accounts...</p>
        </div>
    }
    else if (!accountlist.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-folder2-open display-1 text-muted"></i>
            <h4 class="mt-3 fw-bold">No accounts found</h4>
            <p class="text-muted">Click the button above to create your first account.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var acc in accountlist)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm border-0 h-100 rounded-4 overflow-hidden account-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div>
                                    <h5 class="fw-bold mb-1">@acc.Name</h5>
                                    <span class="badge @(acc.Type == AccountType.CreditCard ? "bg-dark text-white" : "bg-emerald-soft text-emerald") p-2 px-3">
                                        @acc.Type
                                    </span>
                                </div>
                                <div class="rounded-3 bg-light p-3 text-emerald shadow-sm">
                                    <i class="bi @(acc.Type == AccountType.CreditCard ? "bi-credit-card" : "bi-bank") fs-4"></i>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="text-muted small text-uppercase fw-bold">Current Balance</label>
                                <h2 class="fw-bold text-dark mb-0">@acc.Balance.Amount.ToString("C")</h2>
                            </div>

                            @if (acc.Type == AccountType.CreditCard && acc.CreditLimit != null)
                            {
                                <div class="p-3 bg-light rounded-3 mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="text-muted small">Credit Limit</span>
                                        <span class="fw-bold small text-dark">@acc.CreditLimit.Amount.ToString("C")</span>
                                    </div>
                                    @* Optional: Simple progress bar for credit usage *@
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar bg-dark" style="width: 45%"></div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="card-footer bg-white border-top-0 px-4 pb-4">
                            <div class="row g-2">
                                <div class="col-8">
                                    <button class="btn btn-emerald w-100 fw-bold" @onclick="() => AccDetails(acc.Id)">
                                         Details
                                    </button>
                                </div>
                                <div class="col-4">
                                    <button class="btn btn-outline-danger w-100" @onclick="() => DeleteAccount(acc.Id)">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Emerald Theme Colors */
    .text-emerald {
        color: #157347 !important;
    }

    .bg-emerald-soft {
        background-color: rgba(21, 115, 71, 0.1);
    }

    .btn-emerald {
        background-color: #157347;
        border-color: #157347;
        color: white;
        transition: all 0.2s;
    }

        .btn-emerald:hover {
            background-color: #0e5a36;
            color: white;
            transform: translateY(-2px);
        }

    .account-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
    }

        .account-card:hover {
            box-shadow: 0 14px 28px rgba(0,0,0,0.1), 0 10px 10px rgba(0,0,0,0.08) !important;
        }

    .spinner-border.text-emerald {
        color: #157347 !important;
    }
</style>

@code {
    private List<AccountResponse>? accountlist;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _errorMessage = string.Empty;
        var result = await FinanceService.GetAllAccouintsAsync();
        if (result != null && result.IsSuccess)
        {
            accountlist = result.Value;
        }
        else
        {
            accountlist = new List<AccountResponse>();
        }
    }

    private void AccDetails(int Id)
    {
        Nav.NavigateTo($"/account-details/{Id}");
    }

    private async Task DeleteAccount(int Id)
    {
        // Simple skeptical expert check: Add a confirmation before deleting
        var response = await FinanceService.DeleteAccountAsync(Id);
        if (response.IsSuccess)
        {
            await OnInitializedAsync();
        }
        else
        {
            _errorMessage = response.ErrorMessage;
        }
    }
}